N8N_PORT=5678
N8N_HOST=localhost
N8N_PROTOCOL=http

# Set these before running in shared environments.
N8N_BASIC_AUTH_ACTIVE=false
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change-me

# Use a long random value in real usage.
N8N_ENCRYPTION_KEY=replace-with-long-random-string

# Local convenience variable for workflow file paths.
OBSIDIAN_VAULT_PATH=/Users/<you>/Documents/ObsidianVault

# Keep n8n runtime data inside this workspace (useful in sandboxed environments).
N8N_USER_FOLDER=/Users/<you>/path/to/your/project/.n8n

# Local HTTP setup (no TLS)
N8N_SECURE_COOKIE=false

# X API values for the workflow template.
X_BEARER_TOKEN=replace-with-x-bearer-token
X_USER_ID=replace-with-x-user-id
